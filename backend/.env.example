# Copy this file to .env and fill in real values. NEVER commit .env to git.

# ---------- Database ----------
# Local dev: SQLite file at backend/ept.db (created automatically)
DATABASE_URL=sqlite:///./ept.db
# Production (Render Postgres) example:
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ---------- Sessions ----------
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=replace-with-a-random-string-at-least-48-characters-long-for-safety

# ---------- App config ----------
APP_BASE_URL=http://localhost:8000
INVITATION_TTL_HOURS=24

# Comma-separated list of origins allowed to make credentialed API calls.
# Cookie-auth APIs cannot use "*". On Render, set this to your deployed frontend URL.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:5173,http://127.0.0.1:5173

# ---------- AI providers (Day 2) ----------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------- Email / Gmail SMTP (Day 3) ----------
# Get app password at: https://myaccount.google.com/apppasswords (requires 2FA enabled)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=English Proficiency Test
